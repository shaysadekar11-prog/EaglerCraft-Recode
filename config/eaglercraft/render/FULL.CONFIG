# Eaglercraft Render Configuration
# FULL CONFIG - Maximum quality settings

graphics.mode=FULL
render.distance=8
chunk.updates=3
anisotropic.filtering=16
anti.aliasing=4
mipmap.level=4

# Lighting
shadow.quality=HIGH
dynamic.lighting=TRUE
smooth.lighting=TRUE
ambient.occlusion=TRUE

# Effects
water.reflections=TRUE
water.refractions=TRUE
particles.enabled=TRUE
weather.effects=TRUE
fog.enabled=TRUE

# Textures
texture.pack=DEFAULT
texture.resolution=256
connected.textures=TRUE
custom.sky=TRUE

# Performance
use.vbo=TRUE
use.vao=TRUE
fast.render=FALSE
smart.animations=FALSE

# Advanced
entity.distance=256
cloud.height=128
sky.blend=TRUE
biome.blend=2